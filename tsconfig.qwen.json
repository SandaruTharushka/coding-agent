{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "entrypoints/qwen-agent.ts",
    "services/api/qwen-provider.ts",
    "utils/model/qwen-models.ts",
    "agent/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
