{
  "name": "coding-agent-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:vite": "cd ui && npx vite --port 5173",
    "dev:prepare": "tsc -p tsconfig.electron.json",
    "dev:electron": "npx wait-on tcp:5173 && cross-env NODE_ENV=development npx electron dist-electron/main.js",
    "dev": "npm run dev:prepare && npx concurrently -k -n VITE,ELEC -c cyan,yellow \"npm run dev:vite\" \"npm run dev:electron\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:vite": "cd ui && npx vite build",
    "build": "npm run build:electron && npm run build:vite",
    "preview": "npm run build && npx electron dist-electron/main.js"
  },
  "dependencies": {
    "electron": "^28.3.3",
    "lucide-react": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.33",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  }
}
