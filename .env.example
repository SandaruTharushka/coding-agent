# Qwen API key — get yours at https://dashscope.aliyun.com/
QWEN_API_KEY=your_api_key_here

# Base URL (default: DashScope international endpoint)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model to use (qwen-plus | qwen-max | qwen-turbo | qwen-long)
QWEN_MODEL=qwen-plus

# Request timeout in milliseconds
QWEN_TIMEOUT_MS=60000

# Max retries on network/429/5xx errors
QWEN_MAX_RETRIES=3

# Max output tokens per request
QWEN_MAX_TOKENS=8192

# Enable streaming responses (true | false)
QWEN_STREAM=true

# Optional: per-agent model overrides
# QWEN_CODER_MODEL=qwen-max
# QWEN_PLANNER_MODEL=qwen-plus
# QWEN_TESTER_MODEL=qwen-turbo
